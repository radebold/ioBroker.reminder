{
  "common": {
    "name": "reminder",
    "version": "0.0.5",
    "news": {
      "0.0.5": {
        "en": "Added restart helpers: resetAllRuns and config reload commands, automatic cleanup of stale runs after config changes, normalized outgoing recipients, and clearer lastAction diagnostics.",
        "de": "Neustart-Helfer ergänzt: resetAllRuns- und Konfig-Neuladen-Befehle, automatische Bereinigung veralteter Läufe nach Konfigurationsänderungen, Normalisierung ausgehender Empfänger und klarere lastAction-Diagnosen."
      },
      "0.0.3": {
        "en": "Added click-to-reply wa.me links, improved incoming ID matching and ISO timestamp parsing.",
        "de": "Klick-Antworten per wa.me-Link, verbesserter Abgleich eingehender IDs und Parsing von ISO-Zeitstempeln ergänzt."
      },
      "0.0.2": {
        "en": "Install fix for GitHub URL installs. Prepack removed so ioBroker can install directly from the repository.",
        "de": "Installationsfix für GitHub-URL-Installationen. Prepack entfernt, damit ioBroker direkt aus dem Repository installieren kann."
      },
      "0.0.1": {
        "en": "Initial version with weekly WhatsApp reminders, child replies and parent confirmation.",
        "de": "Erste Version mit wöchentlichen WhatsApp-Erinnerungen, Rückmeldung des Kindes und Bestätigung durch Papa."
      }
    },
    "titleLang": {
      "en": "Kinder Haushalts Reminder",
      "de": "Kinder Haushalts Reminder"
    },
    "desc": {
      "en": "Sends rhythmic WhatsApp reminders via open-wa, tracks child replies and requires parent confirmation.",
      "de": "Sendet rhythmische WhatsApp-Erinnerungen über open-wa, verarbeitet Rückmeldungen des Kindes und fordert eine Bestätigung durch Papa an."
    },
    "authors": [
      "Thomas Radebold"
    ],
    "licenseInformation": {
      "license": "MIT",
      "type": "free"
    },
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "icon": "reminder.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/radebold/ioBroker.reminder/main/admin/reminder.png",
    "readme": "https://github.com/radebold/ioBroker.reminder/blob/main/README.md",
    "loglevel": "info",
    "compact": true,
    "connectionType": "local",
    "dataSource": "push",
    "tier": 3,
    "messagebox": true,
    "adminUI": {
      "config": "json"
    },
    "globalDependencies": [
      {
        "admin": ">=6.0.0"
      }
    ],
    "dependencies": [
      {
        "js-controller": ">=5.0.0"
      }
    ],
    "dataFolder": "reminder.%INSTANCE%"
  },
  "native": {
    "openWaInstance": "open-wa.0",
    "incomingStateId": "",
    "replyLinkPhone": "",
    "historyLimit": 100,
    "logIncomingMessages": true,
    "tasks": [
      {
        "enabled": true,
        "id": "treppe",
        "title": "Treppe absaugen",
        "message": "Bitte die Treppe absaugen.",
        "weekday": 3,
        "time": "17:00",
        "childChatId": "120000000000000000@g.us",
        "parentChatId": "4917012345678@c.us",
        "childReminderHours": 3,
        "parentReminderHours": 3,
        "childKeywords": "erledigt,fertig,done",
        "parentKeywords": "ja,bestaetigt,bestätigt,ok"
      }
    ]
  },
  "objects": [],
