{
  "i18n": true,
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "intro": {
          "type": "staticText",
          "newLine": true,
          "sm": 12,
          "text": {
            "en": "Outgoing messages are sent via open-wa using sendTo(instance, 'send', {to, text}). Incoming replies can either be delivered through the configured state path or via sendTo('reminder.X', 'incoming', payload).",
            "de": "Ausgehende Nachrichten werden über open-wa mit sendTo(instance, 'send', {to, text}) gesendet. Eingehende Antworten können entweder über den konfigurierten State-Pfad oder per sendTo('reminder.X', 'incoming', payload) angeliefert werden."
          }
        },
        "openWaInstance": {
          "type": "instance",
          "adapter": "open-wa",
          "label": {
            "en": "open-wa instance",
            "de": "open-wa Instanz"
          },
          "sm": 6
        },
        "incomingStateId": {
          "type": "text",
          "label": {
            "en": "Incoming message state ID",
            "de": "State-ID für eingehende Nachrichten"
          },
          "sm": 6
        },
        "historyLimit": {
          "type": "number",
          "label": {
            "en": "History entries to keep",
            "de": "Anzahl Historieneinträge"
          },
          "min": 10,
          "max": 1000,
          "sm": 3
        },
        "logIncomingMessages": {
          "type": "checkbox",
          "label": {
            "en": "Store last incoming message in info.lastIncoming",
            "de": "Letzte eingehende Nachricht in info.lastIncoming speichern"
          },
          "sm": 9
        }
      }
    },
    "tasksPanel": {
      "type": "panel",
      "label": {
        "en": "Tasks",
        "de": "Aufgaben"
      },
      "items": {
        "tasksHint": {
          "type": "staticText",
          "newLine": true,
          "sm": 12,
          "text": {
            "en": "Each row defines one recurring task. Use exact WhatsApp chat IDs. Child replies should include words like erledigt or fertig. Parent replies should include ja or bestätigt.",
            "de": "Jede Zeile definiert eine wiederkehrende Aufgabe. Verwende die exakten WhatsApp-Chat-IDs. Kind-Antworten sollten Wörter wie erledigt oder fertig enthalten. Papa-Antworten sollten ja oder bestätigt enthalten."
          }
        },
        "tasks": {
          "type": "table",
          "sm": 12,
          "compact": true,
          "showSecondAddAt": 3,
          "clone": "id",
          "titleAttribute": "title",
          "uniqueColumns": [
            "id"
          ],
          "items": [
            {
              "type": "checkbox",
              "attr": "enabled",
              "title": {
                "en": "On",
                "de": "Aktiv"
              },
              "width": 70,
              "default": true
            },
            {
              "type": "text",
              "attr": "id",
              "title": {
                "en": "ID",
                "de": "ID"
              },
              "width": 120,
              "default": "task-1"
            },
            {
              "type": "text",
              "attr": "title",
              "title": {
                "en": "Title",
                "de": "Titel"
              },
              "width": "15%",
              "default": "Treppe absaugen"
            },
            {
              "type": "text",
              "attr": "message",
              "title": {
                "en": "Message",
                "de": "Nachricht"
              },
              "width": "20%",
              "default": "Bitte die Treppe absaugen."
            },
            {
              "type": "select",
              "attr": "weekday",
              "title": {
                "en": "Weekday",
                "de": "Wochentag"
              },
              "width": 120,
              "default": 3,
              "options": [
                {
                  "label": {
                    "en": "Sunday",
                    "de": "Sonntag"
                  },
                  "value": 0
                },
                {
                  "label": {
                    "en": "Monday",
                    "de": "Montag"
                  },
                  "value": 1
                },
                {
                  "label": {
                    "en": "Tuesday",
                    "de": "Dienstag"
                  },
                  "value": 2
                },
                {
                  "label": {
                    "en": "Wednesday",
                    "de": "Mittwoch"
                  },
                  "value": 3
                },
                {
                  "label": {
                    "en": "Thursday",
                    "de": "Donnerstag"
                  },
                  "value": 4
                },
                {
                  "label": {
                    "en": "Friday",
                    "de": "Freitag"
                  },
                  "value": 5
                },
                {
                  "label": {
                    "en": "Saturday",
                    "de": "Samstag"
                  },
                  "value": 6
                }
              ]
            },
            {
              "type": "text",
              "attr": "time",
              "title": {
                "en": "Time HH:mm",
                "de": "Uhrzeit HH:mm"
              },
              "width": 100,
              "default": "17:00"
            },
            {
              "type": "text",
              "attr": "childChatId",
              "title": {
                "en": "Child chat ID",
                "de": "Chat-ID Kind"
              },
              "width": "14%",
              "default": "4917012345678@c.us"
            },
            {
              "type": "text",
              "attr": "parentChatId",
              "title": {
                "en": "Parent chat ID",
                "de": "Chat-ID Papa"
              },
              "width": "14%",
              "default": "4917099999999@c.us"
            },
            {
              "type": "number",
              "attr": "childReminderHours",
              "title": {
                "en": "Child reminder h",
                "de": "Erinnerung Kind h"
              },
              "width": 110,
              "default": 3,
              "min": 1,
              "max": 168
            },
            {
              "type": "number",
              "attr": "parentReminderHours",
              "title": {
                "en": "Parent reminder h",
                "de": "Erinnerung Papa h"
              },
              "width": 110,
              "default": 3,
              "min": 1,
              "max": 168
            },
            {
              "type": "text",
              "attr": "childKeywords",
              "title": {
                "en": "Child keywords",
                "de": "Schlüsselwörter Kind"
              },
              "width": "12%",
              "default": "erledigt,fertig,done"
            },
            {
              "type": "text",
              "attr": "parentKeywords",
              "title": {
                "en": "Parent keywords",
                "de": "Schlüsselwörter Papa"
              },
              "width": "12%",
              "default": "ja,bestaetigt,bestätigt,ok"
            }
          ]
        }
      }
    }
  }
}